    {
      "name": "install",
      "path": "scripts/install.sh",
      "description": "Installs the skill into common local agent skills directories."
    },
    {
      "name": "generate_preview_assets",
      "path": "scripts/generate_preview_assets.py",
      "description": "Regenerates style preview images and interaction GIFs from the preset catalog."
    },
    {
      "name": "audit_static_site",
      "path": "scripts/audit_static_site.py",
      "description": "Checks local static site assets, anchors, duplicate IDs, viewport metadata, image alt attributes, CSS url() references, optional strict SEO/GEO launch metadata, and optional final-delivery placeholders."
    },
    {
      "name": "package_runtime_skill",
      "path": "scripts/package_runtime_skill.py",
      "description": "Creates a lightweight runtime ZIP for team and partner installation in compatible agent tools."
    }
